# transfers example configuration. Copy to `.env` and edit.
#   cp .env.example .env

# --- Required ---

# Chain RPC endpoint (WebSocket).
WS_URL=wss://archive2.mainnet-unit.com

# Postgres connection string to index into.
DATABASE_URL=postgres://postgres:postgres@localhost:55432/subdex

# --- Optional (tuning; defaults shown) ---

# Backfill start height (fresh DB only). Defaults to the last ~20 finalized blocks.
# START_HEIGHT=

# Follow the chain tip after backfill (1) or exit after backfill (0).
# FOLLOW=1

# Serve the GraphQL API alongside indexing (1) or not (0).
# SERVE=1

# Port for the GraphQL server.
# GRAPHQL_PORT=4350

# Log level (e.g. info, debug).
# RUST_LOG=info
